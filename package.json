    "requirements",
    "coverage",
    "claude-code"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
