{
  "name": "@set-trace/cli",
  "version": "0.1.0",
  "description": "Claim traceability tool — extract traces from source documents, verify coverage against targets",
  "type": "module",
  "bin": {
    "set-trace": "./dist/cli.js"
  },
  "files": [
    "dist",
    "presets",
    "prompts",
    "templates"
  ],
  "scripts": {
