{
  "name": "set-trace-lsp",
  "displayName": "set-trace",
  "description": "Claim traceability visualization for source documents",
  "version": "0.2.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Linters"],
  "activationEvents": ["onLanguage:markdown"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "set-trace",
      "properties": {
        "set-trace.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to python3 with pygls installed"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
